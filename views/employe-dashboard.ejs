<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARIS - Mon Presence</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: #f5f7fa;
    }
    .header {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      color: white;
      padding: 20px;
      border-radius: 0 0 20px 20px;
    }
    .card {
      border: none;
      border-radius: 15px;
      box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }
    .card-header {
      background: white;
      border-bottom: 2px solid #f0f0f0;
      border-radius: 15px 15px 0 0 !important;
      font-weight: bold;
      color: #1e3c72;
    }
    .qr-card {
      background: white;
      border-radius: 20px;
      padding: 30px;
      text-align: center;
      box-shadow: 0 10px 30px rgba(0,0,0,0.15);
    }
    .qr-code {
      border: 5px solid #1e3c72;
      border-radius: 10px;
      padding: 10px;
      display: inline-block;
      margin: 20px 0;
    }
    .presence-badge {
      display: inline-block;
      padding: 8px 20px;
      border-radius: 20px;
      font-weight: bold;
      font-size: 14px;
    }
    .presence-entrer {
      background: #d4edda;
      color: #155724;
    }
    .presence-sortie {
      background: #f8d7da;
      color: #721c24;
    }
    .stat-card {
      text-align: center;
      padding: 20px;
    }
    .stat-number {
      font-size: 32px;
      font-weight: bold;
      color: #1e3c72;
    }
    .stat-label {
      color: #666;
      font-size: 14px;
    }
    .btn-pointage {
      background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
      border: none;
      border-radius: 15px;
      padding: 20px 40px;
      font-size: 18px;
      font-weight: bold;
      color: white;
      cursor: pointer;
      transition: transform 0.2s;
    }
    .btn-pointage:hover {
      transform: scale(1.05);
    }
    .btn-pointage:disabled {
      opacity: 0.6;
      cursor: not-allowed;
      transform: none;
    }
    .timeline-item {
      padding: 10px 0;
      border-left: 3px solid #1e3c72;
      padding-left: 20px;
      margin-left: 10px;
    }
    .timeline-item::before {
      content: '';
      position: absolute;
      left: -8px;
      top: 15px;
      width: 13px;
      height: 13px;
      border-radius: 50%;
      background: #1e3c72;
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="d-flex justify-content-between align-items-center">
      <div>
        <h4><i class="fas fa-qrcode me-2"></i>ARIS Presence</h4>
      </div>
      <a href="/employe-logout" class="btn btn-outline-light btn-sm">
        <i class="fas fa-sign-out-alt"></i> Déconnexion
      </a>
    </div>
  </div>

  <div class="container mt-4">
    <!-- Info Employé -->
    <div class="card mb-4">
      <div class="card-body text-center">
        <div class="d-flex align-items-center justify-content-center mb-3">
          <div style="width: 60px; height: 60px; background: #1e3c72; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-size: 24px;">
            <%= employe.prenom.charAt(0) %><%= employe.nom.charAt(0) %>
          </div>
        </div>
        <h5><%= employe.prenom %> <%= employe.nom %></h5>
        <p class="text-muted mb-1"><%= employe.poste || 'Employé' %></p>
        <span class="badge bg-primary">Code: <%= employe.badge_id || employe.id_affichage %></span>
      </div>
    </div>

    <!-- Bouton Pointage -->
    <div class="card mb-4">
      <div class="card-body text-center">
        <h6 class="mb-3">Pointer aujourd'hui</h6>
        <button id="btnPointage" class="btn-pointage" onclick="fairePointage()">
          <i class="fas fa-hand-pointer me-2"></i>
          <span id="btnText">Pointer</span>
        </button>
        <p id="pointageStatus" class="mt-3 text-muted"></p>
      </div>
    </div>

    <div class="row">
      <!-- QR Code -->
      <div class="col-md-6 mb-4">
        <div class="qr-card">
          <h5><i class="fas fa-qrcode me-2"></i>Mon Badge</h5>
          <p class="text-muted">Présenter ce code au scanner</p>
          <div class="qr-code">
            <% if (qrDataUrl) { %>
              <img src="<%= qrDataUrl %>" alt="QR Code" width="200">
            <% } else { %>
              <div style="width: 200px; height: 200px; background: #eee; display: flex; align-items: center; justify-content: center;">
                <i class="fas fa-qrcode fa-3x text-muted"></i>
              </div>
            <% } %>
          </div>
          <p class="text-muted small">ID: <%= employe.id_affichage || employe.id %></p>
        </div>
      </div>

      <!-- Historique -->
      <div class="col-md-6 mb-4">
        <div class="card">
          <div class="card-header">
            <i class="fas fa-history me-2"></i>Historique aujourd'hui
          </div>
          <div class="card-body" style="max-height: 300px; overflow-y: auto;">
            <% if (presences.length > 0) { %>
              <% presences.forEach(function(p) { %>
                <div class="timeline-item position-relative" data-scanned-at="<%= p.scanned_at %>">
                  <div class="d-flex justify-content-between align-items-center">
                    <span class="presence-badge <%= p.type === 'entrer' ? 'presence-entrer' : 'presence-sortie' %>">
                      <i class="fas <%= p.type === 'entrer' ? 'fa-sign-in-alt' : 'fa-sign-out-alt' %> me-1"></i>
                      <%= p.type === 'entrer' ? 'Entrée' : 'Sortie' %>
                    </span>
                    <small class="text-muted time-display"></small>
                  </div>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted text-center">Aucun pointage aujourd'hui</p>
            <% } %>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">
            <i class="fas fa-calendar-week me-2"></i>Cette semaine
          </div>
          <div class="card-body" style="max-height: 200px; overflow-y: auto;">
            <% if (lastWeek.length > 0) { %>
              <% var dates = {}; %>
              <% lastWeek.forEach(function(p) { %>
                <% var date = p.scanned_at.split(' ')[0]; %>
                <% if (!dates[date]) { dates[date] = []; } %>
                <% dates[date].push(p); %>
              <% }); %>
              <% Object.keys(dates).forEach(function(date) { %>
                <div class="mb-2">
                  <strong><%= new Date(date).toLocaleDateString('fr-FR', {weekday: 'short', day: 'numeric', month: 'short'}) %></strong>
                  <% dates[date].forEach(function(p) { %>
                    <span class="presence-badge <%= p.type === 'entrer' ? 'presence-entrer' : 'presence-sortie' %> ms-1">
                      <%= p.type === 'entrer' ? 'E' : 'S' %>
                    </span>
                  <% }); %>
                </div>
              <% }); %>
            <% } else { %>
              <p class="text-muted text-center">Aucune présence cette semaine</p>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    let canPoint = true;
    
    function fairePointage() {
      if (!canPoint) return;
      
      const btn = document.getElementById('btnPointage');
      const btnText = document.getElementById('btnText');
      const status = document.getElementById('pointageStatus');
      
      btn.disabled = true;
      btnText.textContent = 'Pointage en cours...';
      
      fetch('/employe-pointage', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'}
      })
      .then(r => r.json())
      .then(data => {
        if (data.ok) {
          const type = data.type === 'entrer' ? 'Entrée' : 'Sortie';
          status.innerHTML = '<span class="text-success"><i class="fas fa-check-circle"></i> ' + type + ' enregistrée!</span>';
          setTimeout(() => location.reload(), 1500);
        } else {
          status.innerHTML = '<span class="text-danger"><i class="fas fa-times-circle"></i> ' + data.error + '</span>';
          btn.disabled = false;
          btnText.textContent = 'Réessayer';
        }
      })
      .catch(err => {
        status.innerHTML = '<span class="text-danger">Erreur de connexion</span>';
        btn.disabled = false;
        btnText.textContent = 'Réessayer';
      });
    }
  </script>
  <script>
    // Madagascar timezone (UTC+3)
    function toMadagascarTime(utcStr) {
      try {
        var d = new Date(utcStr.replace(' ', 'T') + 'Z');
        var h = String(d.getUTCHours() + 1).padStart(2, '0');
        var m = String(d.getUTCMinutes()).padStart(2, '0');
        return h + 'h' + m;
      } catch(e) { return '--'; }
    }
    
    document.querySelectorAll('.timeline-item[data-scanned-at]').forEach(function(item) {
      var scannedAt = item.getAttribute('data-scanned-at');
      var timeEl = item.querySelector('.time-display');
      if (scannedAt && timeEl) {
        timeEl.textContent = toMadagascarTime(scannedAt);
      }
    });
  </script>
</body>
</html>
