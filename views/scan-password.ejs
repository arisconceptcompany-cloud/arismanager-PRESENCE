<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Changer mot de passe - ARIS Scanner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .card {
      background: white;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      padding: 40px;
      max-width: 450px;
      width: 100%;
    }
    .card-header {
      text-align: center;
      margin-bottom: 30px;
      border-bottom: none;
      padding: 0;
    }
    .card-header h3 {
      color: #1e3c72;
      font-weight: bold;
    }
    .card-header i {
      font-size: 50px;
      color: #1e3c72;
      margin-bottom: 15px;
    }
    .form-label {
      font-weight: 600;
      color: #333;
    }
    .btn-primary {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      border: none;
      padding: 12px;
      font-weight: bold;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #2a5298 0%, #1e3c72 100%);
    }
    .alert { border-radius: 10px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-header">
      <i class="fas fa-key"></i>
      <h3>Changer le mot de passe</h3>
      <p class="text-muted">Scanner: <%= user.scanUserName %></p>
    </div>
    
    <% if (error) { %>
    <div class="alert alert-danger"><i class="fas fa-times-circle me-2"></i><%= error %></div>
    <% } %>
    
    <% if (success) { %>
    <div class="alert alert-success"><i class="fas fa-check-circle me-2"></i><%= success %></div>
    <% } %>
    
    <form method="POST" action="/scan-password">
      <div class="mb-3">
        <label class="form-label">Mot de passe actuel</label>
        <input type="password" name="current_password" class="form-control" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Nouveau mot de passe</label>
        <input type="password" name="new_password" class="form-control" required minlength="4">
      </div>
      <div class="mb-4">
        <label class="form-label">Confirmer le mot de passe</label>
        <input type="password" name="confirm_password" class="form-control" required minlength="4">
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="fas fa-save me-2"></i>Changer le mot de passe
      </button>
    </form>
    
    <div class="text-center mt-4">
      <a href="/scan" class="text-muted text-decoration-none">
        <i class="fas fa-arrow-left me-1"></i> Retour au scanner
      </a>
    </div>
  </div>
</body>
</html>
