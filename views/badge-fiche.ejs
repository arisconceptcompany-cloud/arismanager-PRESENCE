<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof isExemple !== 'undefined' && isExemple ? 'Exemple de badge' : 'Badge ' + (employee.badge_id || '') %> - PresenceAris</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    /* Design badge exact comme maquette : bordure blanche, zone grise (2/3), zone magenta (1/3) */
    :root {
      --badge-border: #fff;
      --badge-top: #2b2b2b;
      --badge-bottom: #e84a8a;
      --badge-white: #fff;
    }
    .badge-container { max-width: 86mm; margin: 20px auto; }
    .badge-print {
      width: 86mm;
      min-height: 54mm;
      border: 2px solid var(--badge-border);
      border-radius: 8px;
      overflow: hidden;
      background: var(--badge-top);
      color: var(--badge-white);
      position: relative;
    }
    /* Zone sombre — 2/3 hauteur, texture diagonale */
    .badge-top {
      min-height: 66%;
      padding: 10px 12px;
      display: flex;
      align-items: flex-start;
      gap: 12px;
      background: var(--badge-top);
      position: relative;
    }
    .badge-top::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        -45deg,
        transparent,
        transparent 4px,
        rgba(255,255,255,0.02) 4px,
        rgba(255,255,255,0.02) 5px
      );
      pointer-events: none;
    }
    /* Photo rectangulaire coins arrondis, bordure bleu clair */
    .badge-photo {
      width: 40px;
      height: 48px;
      border-radius: 6px;
      border: 2px solid #4da6ff;
      background: #444;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      font-size: 11px;
      flex-shrink: 0;
      overflow: hidden;
      position: relative;
      z-index: 1;
    }
    .badge-photo img { width: 100%; height: 100%; object-fit: cover; }
    .badge-info-wrap { flex: 1; min-width: 0; position: relative; z-index: 1; }
    .badge-id { font-size: 17px; font-weight: bold; margin: 0 0 6px; letter-spacing: 0.02em; }
    .badge-id .id-num { font-size: 19px; }
    .badge-nom { font-size: 12px; font-weight: bold; margin: 0; text-transform: uppercase; letter-spacing: 0.03em; }
    .badge-prenom { font-size: 11px; font-weight: bold; margin: 2px 0 0; text-transform: uppercase; opacity: 0.95; }
    /* Filigrane / watermark poste en bas à droite */
    .badge-fonction {
      position: absolute;
      right: 12px;
      bottom: 4px;
      font-size: 11px;
      opacity: 0.4;
      font-style: italic;
      font-family: Georgia, 'Times New Roman', serif;
      text-transform: uppercase;
      color: #aaa;
    }
    .badge-sep { height: 2px; background: rgba(255,255,255,0.25); }
    /* Zone magenta — 1/3 hauteur */
    .badge-bottom {
      min-height: 34%;
      padding: 8px 12px;
      background: var(--badge-bottom);
      display: flex;
      align-items: center;
      gap: 10px;
      position: relative;
    }
    .badge-bottom::before {
      content: '';
      position: absolute;
      inset: 0;
      background: repeating-linear-gradient(
        45deg,
        transparent,
        transparent 4px,
        rgba(255,255,255,0.03) 4px,
        rgba(255,255,255,0.03) 5px
      );
      pointer-events: none;
    }
    .badge-logo { height: 26px; width: auto; flex-shrink: 0; position: relative; z-index: 1; }
    .badge-adresse-wrap { flex: 1; min-width: 0; display: flex; align-items: center; gap: 6px; position: relative; z-index: 1; }
    .badge-pin { flex-shrink: 0; width: 16px; height: 16px; }
    .badge-adresse { font-size: 7.5px; color: var(--badge-white); line-height: 1.4; margin: 0; }
    /* QR code plus grand — presque hauteur de la zone magenta */
    .badge-qr { flex-shrink: 0; position: relative; z-index: 1; display: flex; align-items: center; }
    .badge-qr img { width: 48px; height: 48px; display: block; background: #fff; border-radius: 4px; padding: 2px; }
    .no-print { margin-top: 16px; text-align: center; }
    @media print {
      body { background: #fff; }
      .no-print { display: none !important; }
      .badge-container { margin: 0; }
    }
  </style>
</head>
<body>
  <div class="badge-container">
    <div class="badge-print">
      <div class="badge-top">
        <div class="badge-photo">
          <% if (employee.photo) { %>
          <img src="<%= employee.photo.startsWith('/') ? employee.photo : '/photos/' + employee.photo %>" alt="">
          <% } else {
            const initiales = ((employee.prenom || '')[0] || '') + ((employee.nom || '')[0] || '');
          %>
          <span><%= (initiales || '?').toUpperCase() %></span>
          <% } %>
        </div>
        <div class="badge-info-wrap">
          <p class="badge-id"><%- (employee.id_affichage != null ? 'ID:<span class="id-num">' + String(employee.id_affichage).padStart(4,'0') + '</span>' : (employee.badge_id || 'ID:<span class="id-num">0001</span>')) %></p>
          <p class="badge-nom"><%= (employee.nom || '').toUpperCase() %></p>
          <p class="badge-prenom"><%= (employee.prenom || '').toUpperCase() %></p>
          <p class="badge-fonction"><%= (employee.poste || '').toUpperCase() %></p>
        </div>
      </div>
      <div class="badge-sep"></div>
      <div class="badge-bottom">
        <img src="/logo.png" alt="ARIS" class="badge-logo">
        <div class="badge-adresse-wrap">
          <svg class="badge-pin" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="12" cy="10" r="4" fill="#4da6ff"/>
            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7z" fill="#e74c3c" stroke="#c0392b" stroke-width="0.5"/>
          </svg>
          <% 
              const _adr = typeof adresseSociete !== 'undefined' ? adresseSociete : (employee.adresse || 'Lot II T 104 A lavoloha, Antananarivo 102');
              const _adrLines = _adr.split(',').map(function(s) { return s.trim(); }).join('<br>');
            %>
            <p class="badge-adresse"><%- _adrLines %></p>
        </div>
        <% if (qrDataUrl) { %>
        <div class="badge-qr"><img src="<%= qrDataUrl %>" alt="QR <%= employee.badge_id || employee.id_affichage %>"></div>
        <% } %>
      </div>
    </div>
  </div>
  <div class="no-print badge-actions">
    <% if (typeof isExemple === 'undefined' || !isExemple) { %>
    <a href="/badge/<%= employee.badge_id %>/badge.pdf" class="btn btn-primary" download>Télécharger badge PDF</a>
    <% } %>
    <button type="button" onclick="window.print()" class="btn btn-secondary">Imprimer</button>
    <% if (typeof hasBadgePdfTemplate !== 'undefined' && hasBadgePdfTemplate) { %>
    <a href="/Badge.pdf" class="btn" target="_blank">Voir modèle Badge.pdf</a>
    <% } %>
    <a href="/badges" class="btn">Retour aux badges</a>
  </div>
  <% if (typeof isExemple !== 'undefined' && isExemple) { %>
  <p class="no-print" style="text-align:center; color: var(--text-muted); font-size: 0.9rem; margin-top: 12px;">Ce badge utilise les données de la base. Les vrais badges sont modifiables depuis la fiche employé.</p>
  <% } %>
  <style>.badge-actions { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; }</style>
</body>
</html>
