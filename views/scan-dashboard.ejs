<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARIS - Scanner</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js" type="text/javascript"></script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <style>
    /* Thème basé sur le logo ARIS */
    :root {
      --aris-primary: #0077b6;
      --aris-secondary: #00b4d8;
      --aris-dark: #023e8a;
      --aris-light: #90e0ef;
    }
    body {
      background: #f5f7fa;
    }
    
    /* Responsive header */
    .header {
      background: linear-gradient(135deg, var(--aris-dark) 0%, var(--aris-primary) 50%, var(--aris-secondary) 100%);
      color: white;
      padding: 12px 15px;
      border-radius: 0 0 15px 15px;
    }
    .header .d-flex {
      flex-wrap: wrap !important;
    }
    .header h4 {
      font-size: 1rem;
    }
    .header small {
      font-size: 0.75rem;
    }
    .aris-logo {
      height: 40px;
      width: auto;
      object-fit: contain;
    }
    .aris-logo-small {
      height: 35px;
      width: auto;
      object-fit: contain;
    }
    
    /* Responsive scanner box */
    .scanner-box {
      background: white;
      border-radius: 15px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.15);
      padding: 15px;
      margin-bottom: 15px;
    }
    #reader {
      width: 100%;
      border-radius: 10px;
      overflow: hidden;
      min-height: 250px !important;
    }
    #reader video {
      border-radius: 10px;
    }
    
    /* Responsive manual input */
    .manual-input {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-top: 15px;
    }
    .manual-input input {
      width: 100%;
      border-radius: 10px;
      padding: 12px;
      border: 2px solid #e0e0e0;
    }
    .manual-input button {
      width: 100%;
      border-radius: 10px;
      padding: 12px 25px;
    }
    
    /* Responsive result card */
    .result-card {
      border-radius: 15px;
      padding: 20px;
      text-align: center;
      margin-top: 15px;
      animation: popIn 0.3s ease;
    }
    .result-icon {
      font-size: 50px !important;
    }
    .result-name {
      font-size: 20px !important;
    }
    .result-type {
      font-size: 24px !important;
    }
    .result-time {
      font-size: 18px !important;
    }
    .emp-photo, .emp-photo-placeholder {
      width: 70px !important;
      height: 70px !important;
      font-size: 24px !important;
    }
    
    @keyframes popIn {
      from { transform: scale(0.8); opacity: 0; }
      to { transform: scale(1); opacity: 1; }
    }
    .result-entrer {
      background: linear-gradient(135deg, #d4edda 0%, #c3e6cb 100%);
      border: 3px solid #28a745;
    }
    .result-sortie {
      background: linear-gradient(135deg, #f8d7da 0%, #f5c6cb 100%);
      border: 3px solid #dc3545;
    }
    .result-invalide {
      background: linear-gradient(135deg, #fff3cd 0%, #ffeeba 100%);
      border: 3px solid #ffc107;
    }
    .result-icon {
      font-size: 80px;
      margin-bottom: 15px;
    }
    .result-entrer .result-icon { color: #28a745; }
    .result-sortie .result-icon { color: #dc3545; }
    .result-invalide .result-icon { color: #ffc107; }
    .result-name {
      font-size: 28px;
      font-weight: bold;
      color: #333;
    }
    .result-type {
      font-size: 36px;
      font-weight: bold;
      margin: 15px 0;
    }
    .result-entrer .result-type { color: #28a745; }
    .result-sortie .result-type { color: #dc3545; }
    .result-invalide .result-type { color: #856404; }
    .result-time {
      font-size: 24px;
      color: #666;
    }
    .result-date {
      font-size: 16px;
      color: #999;
      margin-top: 5px;
    }
    .result-poste {
      font-size: 18px;
      color: #666;
      margin-top: 5px;
    }
    .result-badge-id {
      font-size: 14px;
      color: #888;
      margin-top: 10px;
      padding: 8px 15px;
      background: rgba(0,0,0,0.1);
      border-radius: 20px;
      display: inline-block;
    }
    .result-photo {
      margin-bottom: 15px;
    }
    .emp-photo {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      object-fit: cover;
      border: 4px solid white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    .emp-photo-placeholder {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--aris-dark), var(--aris-primary));
      color: white;
      font-size: 36px;
      font-weight: bold;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 4px solid white;
      box-shadow: 0 4px 15px rgba(0,0,0,0.2);
      margin: 0 auto;
    }
    .today-list {
      background: white;
      border-radius: 15px;
      box-shadow: 0 2px 15px rgba(0,0,0,0.1);
    }
    .today-list .card-header {
      background: white;
      border-bottom: 2px solid #f0f0f0;
      border-radius: 15px 15px 0 0 !important;
      font-weight: bold;
      color: var(--aris-primary);
    }
    .scan-item {
      display: flex;
      align-items: center;
      padding: 12px 15px;
      border-bottom: 1px solid #f0f0f0;
    }
    .scan-item:last-child {
      border-bottom: none;
    }
    .scan-badge {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-weight: bold;
      color: white;
      margin-right: 15px;
    }
    .scan-entrer { background: #28a745; }
    .scan-sortie { background: #dc3545; }
    .scan-info { flex: 1; }
    .scan-name { font-weight: bold; color: #333; }
    .scan-poste { font-size: 12px; color: #666; }
    .scan-time { font-weight: bold; color: var(--aris-primary); }
    
    /* Mobile responsive - Tab navigation */
    .nav-tabs .nav-link {
      padding: 8px 10px;
      font-size: 0.85rem;
    }
    .nav-tabs .nav-link i {
      margin-right: 3px;
    }
    
    /* Mobile responsive - Containers */
    .container {
      padding-left: 10px;
      padding-right: 10px;
    }
    .mt-4 {
      margin-top: 1rem !important;
    }
    .mb-4 {
      margin-bottom: 1rem !important;
    }
    
    /* Mobile responsive - List items */
    .scan-item {
      padding: 10px;
    }
    .scan-item > div {
      width: 100% !important;
    }
    .scan-item > div:first-child {
      margin-bottom: 8px;
    }
    
    /* Mobile responsive - Badge list */
    .emp-item {
      padding: 10px !important;
      flex-wrap: wrap !important;
    }
    .emp-info {
      width: calc(100% - 45px) !important;
    }
    
    /* Mobile responsive - Toast notifications */
    .toast-notification {
      left: 10px;
      right: 10px;
      padding: 12px 16px;
      font-size: 0.9rem;
    }
    
    /* Hide non-essential elements on mobile */
    @media (max-width: 576px) {
      .header .text-end {
        display: none !important;
      }
      .header {
        padding: 10px 12px;
      }
      .aris-logo {
        height: 35px;
      }
      .header h4 {
        font-size: 0.9rem;
      }
      .header small {
        font-size: 0.7rem;
      }
      .scanner-box {
        padding: 10px;
        border-radius: 10px;
      }
      .result-card {
        padding: 15px;
      }
      .result-icon {
        font-size: 40px !important;
      }
      .result-name {
        font-size: 18px !important;
      }
      .result-type {
        font-size: 20px !important;
      }
      .result-poste {
        font-size: 14px !important;
      }
      .result-badge-id {
        font-size: 12px !important;
        padding: 6px 10px !important;
      }
      #currentTime {
        font-size: 14px !important;
      }
      #currentDate {
        font-size: 11px !important;
      }
    }
  </style>
</head>
<body>
  <div class="header">
    <div class="d-flex justify-content-between align-items-center">
      <div class="d-flex align-items-center">
        <img src="/logo.png" alt="ARIS" class="aris-logo me-3">
        <div>
          <h4 class="mb-0">ARIS Scanner</h4>
          <small>Responsable: <%= user.scanUserName %></small>
        </div>
      </div>
      <div class="text-end">
        <div id="currentTime" style="font-size: 18px; font-weight: bold;"></div>
        <small id="currentDate"></small>
      </div>
      <div class="d-flex gap-2">
        <a href="/scan-password" class="btn btn-outline-light btn-sm" title="Changer mot de passe">
          <i class="fas fa-key"></i>
        </a>
        <a href="/scan-logout" class="btn btn-outline-light btn-sm">
          <i class="fas fa-sign-out-alt"></i>
        </a>
      </div>
    </div>
  </div>

  <!-- Tabs -->
  <div class="container mt-3 px-3">
    <ul class="nav nav-tabs nav-fill" id="scanTabs" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active" id="scanner-tab" data-bs-toggle="tab" data-bs-target="#scanner-pane" type="button" role="tab">
          <i class="fas fa-qrcode me-1"></i> Scanner
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="employes-tab" data-bs-toggle="tab" data-bs-target="#employes-pane" type="button" role="tab">
          <i class="fas fa-users me-1"></i> Employés
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link" id="historique-tab" data-bs-toggle="tab" data-bs-target="#historique-pane" type="button" role="tab">
          <i class="fas fa-history me-1"></i> Historique
        </button>
      </li>
      <li class="nav-item" role="presentation">
        <a class="nav-link" href="/scan-presences" target="_blank">
          <i class="fas fa-calendar me-1"></i> Par date
        </a>
      </li>
    </ul>
  </div>

  <div class="tab-content" id="scanTabsContent">
    <!-- Scanner Tab -->
    <div class="tab-pane fade show active" id="scanner-pane" role="tabpanel">
      <div class="container mt-4">
        <!-- Scanner -->
        <div class="scanner-box">
          <h5 class="text-center mb-3"><i class="fas fa-camera me-2"></i>Scanner le badge</h5>
          <div id="reader"></div>
          
          <div class="manual-input">
            <input type="text" id="manualCode" placeholder="Entrer le code badge..." onkeypress="if(event.key==='Enter')submitManualCode()">
            <button class="btn btn-primary" id="btnValidate" onclick="submitManualCode()">
              <i class="fas fa-check"></i> Valider
            </button>
          </div>
          
          <div class="mt-3 text-center">
            <button class="btn btn-outline-primary" onclick="openCameraScanner()">
              <i class="fas fa-camera me-2"></i> Ouvrir la caméra
            </button>
          </div>
        </div>

        <!-- Result -->
        <div id="resultContainer"></div>
      </div>
    </div>

    <!-- Employes Tab -->
    <div class="tab-pane fade" id="employes-pane" role="tabpanel">
      <div class="container mt-4">
        <div class="today-list card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-users me-2"></i>Liste des employés</span>
            <button class="btn btn-sm btn-outline-primary" onclick="loadEmployeesStatus()">
              <i class="fas fa-sync"></i>
            </button>
          </div>
          <div class="card-body p-0" id="employeesList">
            <div class="text-center text-muted p-3">
              <i class="fas fa-spinner fa-spin me-2"></i> Chargement...
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Historique Tab -->
    <div class="tab-pane fade" id="historique-pane" role="tabpanel">
      <div class="container mt-4">
        <div class="today-list card">
          <div class="card-header d-flex justify-content-between align-items-center">
            <span><i class="fas fa-list me-2"></i>Pointages aujourd'hui</span>
            <button class="btn btn-sm btn-outline-primary" onclick="loadTodayList()">
              <i class="fas fa-sync"></i>
            </button>
          </div>
          <div class="card-body p-0" id="todayList">
            <div class="text-center text-muted p-3">
              <i class="fas fa-spinner fa-spin me-2"></i> Chargement...
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Madagascar timezone (UTC+3)
    function toMadagascarTime(utcStr) {
      try {
        var d = new Date(utcStr.replace(' ', 'T') + 'Z');
        var h = String(d.getUTCHours() + 1).padStart(2, '0');
        var m = String(d.getUTCMinutes()).padStart(2, '0');
        return h + 'h' + m;
      } catch(e) { return '--'; }
    }
    
    // Debug: show errors on screen
    window.onerror = function(msg, url, line, col, error) {
      var errDiv = document.createElement('div');
      errDiv.style.cssText = 'position:fixed;bottom:0;left:0;right:0;background:red;color:white;padding:10px;z-index:9999;font-size:12px;';
      errDiv.textContent = 'Erreur: ' + msg + ' (ligne ' + line + ')';
      document.body.appendChild(errDiv);
      console.error(msg, line);
    };
    
    let html5QrcodeScanner = null;
    let lastScannedCode = '';
    let scanCooldown = false;
    let cooldownSeconds = 0;
    let cooldownInterval = null;
    let cameraActive = false;

    function openCameraScanner() {
      initScanner();
    }

    function onScanSuccess(decodedText, decodedResult) {
      if (scanCooldown || decodedText === lastScannedCode) return;
      
      lastScannedCode = decodedText;
      scanCooldown = true;
      
      processBadge(decodedText);
      
      startCooldown();
    }

    function startCooldown() {
      cooldownSeconds = 10;
      updateCooldownDisplay();
      
      document.getElementById('manualCode').disabled = true;
      document.getElementById('btnValidate').disabled = true;
      
      cooldownInterval = setInterval(() => {
        cooldownSeconds--;
        updateCooldownDisplay();
        
        if (cooldownSeconds <= 0) {
          clearInterval(cooldownInterval);
          cooldownInterval = null;
          scanCooldown = false;
          lastScannedCode = '';
          document.getElementById('manualCode').disabled = false;
          document.getElementById('btnValidate').disabled = false;
        }
      }, 1000);
    }

    function updateCooldownDisplay() {
      const manualInput = document.getElementById('manualCode').closest('.manual-input');
      let cooldownEl = document.getElementById('cooldownDisplay');
      
      if (!cooldownEl) {
        cooldownEl = document.createElement('div');
        cooldownEl.id = 'cooldownDisplay';
        cooldownEl.className = 'text-center mt-2';
        cooldownEl.style.cssText = 'color: #dc3545; font-weight: bold; font-size: 14px;';
        manualInput.parentNode.insertBefore(cooldownEl, manualInput.nextSibling);
      }
      
      if (cooldownSeconds > 0) {
        cooldownEl.innerHTML = `<i class="fas fa-clock me-1"></i> Attendez ${cooldownSeconds}s avant le prochain scan`;
      } else {
        cooldownEl.innerHTML = '';
      }
    }

    function onScanFailure(error) {
      // Silent failure - normal for continuous scanning
    }

    function submitManualCode() {
      if (scanCooldown) return;
      
      const code = document.getElementById('manualCode').value.trim();
      if (code) {
        lastScannedCode = code;
        scanCooldown = true;
        processBadge(code);
        document.getElementById('manualCode').value = '';
        startCooldown();
      }
    }

    document.getElementById('manualCode').addEventListener('keypress', function(e) {
      if (e.key === 'Enter') {
        submitManualCode();
      }
    });

    function processBadge(code) {
      fetch('/api/scan-badge', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ badgeCode: code })
      })
      .then(r => r.json())
      .then(data => {
        showResult(data);
        loadTodayList();
        loadEmployeesStatus();
      })
      .catch(err => {
        showResult({ ok: false, error: 'Erreur de connexion' });
      });
    }

    function showResult(data) {
      const container = document.getElementById('resultContainer');
      
      if (!data.ok) {
        container.innerHTML = `
          <div class="result-card result-invalide">
            <div class="result-icon"><i class="fas fa-times-circle"></i></div>
            <div class="result-name">${data.error || 'Erreur'}</div>
            <div class="result-time"><i class="fas fa-exclamation-triangle"></i> Badge invalide</div>
          </div>
        `;
        return;
      }
      
      const emp = data.employe;
      const typeLabel = data.type === 'entrer' ? 'ENTRÉE' : 'SORTIE';
      const typeClass = data.type === 'entrer' ? 'result-entrer' : 'result-sortie';
      const typeIcon = data.type === 'entrer' ? 'fa-sign-in-alt' : 'fa-sign-out-alt';
      
      // Use client local time
      const now = new Date();
      const timeStr = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const dateStr = now.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      
      let photoHtml = '';
      if (emp.photo) {
        photoHtml = `<img src="${emp.photo}" alt="${emp.prenom} ${emp.nom}" class="emp-photo">`;
      } else {
        const initials = emp.prenom.charAt(0).toUpperCase() + emp.nom.charAt(0).toUpperCase();
        photoHtml = `<div class="emp-photo-placeholder">${initials}</div>`;
      }
      
      container.innerHTML = `
        <div class="result-card ${typeClass}">
          <div class="result-photo">${photoHtml}</div>
          <div class="result-icon"><i class="fas ${typeIcon}"></i></div>
          <div class="result-name">${emp.prenom} ${emp.nom}</div>
          <div class="result-poste">${emp.poste || 'Employé'}</div>
          <div class="result-type">${typeLabel}</div>
          <div class="result-time"><i class="far fa-clock"></i> ${timeStr}</div>
          <div class="result-date">${dateStr}</div>
          <div class="result-badge-id"><i class="fas fa-id-badge"></i> Badge: ${emp.badge_id || emp.id_affichage || 'Non assigné'}</div>
        </div>
      `;
    }

    function loadTodayList() {
      try {
      var container = document.getElementById('todayList');
      if (!container) return;
      
      fetch('/api/today-presences')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!container) return;
        if (data.length === 0) {
          container.innerHTML = '<div class="text-center text-muted p-3">Aucun pointage aujourd\'hui</div>';
          return;
        }
        
        const employees = {};
        data.forEach(function(p) {
          const key = p.employee_id;
          if (!employees[key]) {
            employees[key] = {
              nom: p.nom,
              prenom: p.prenom,
              poste: p.poste,
              pointages: []
            };
          }
          employees[key].pointages.push({
            type: p.type,
            time: toMadagascarTime(p.scanned_at),
            fullTime: p.scanned_at
          });
        });
        
        let html = '';
        Object.values(employees).forEach(function(emp) {
          emp.pointages.sort(function(a, b) { return new Date(a.fullTime) - new Date(b.fullTime); });
          
          const entrees = emp.pointages.filter(function(p) { return p.type === 'entrer'; });
          const sorties = emp.pointages.filter(function(p) { return p.type === 'sortie'; });
          
          const entreesStr = entrees.map(function(e) { return e.time; }).join('<br>');
          const sortiesStr = sorties.map(function(s) { return s.time; }).join('<br>');
          
          html += `
            <div class="scan-item" style="flex-wrap: wrap;">
              <div class="scan-info" style="width: 100%; display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                <div>
                  <div class="scan-name">${emp.prenom} ${emp.nom}</div>
                  <div class="scan-poste">${emp.poste || ''}</div>
                </div>
                <div class="badge bg-secondary">${emp.pointages.length} pointage(s)</div>
              </div>
              <div style="width: 100%; display: flex; gap: 10px;">
                <div style="flex: 1; background: #d4edda; border-radius: 8px; padding: 8px; text-align: center;">
                  <div style="color: #155724; font-weight: bold; font-size: 12px; margin-bottom: 4px;">
                    <i class="fas fa-sign-in-alt me-1"></i> ENTRÉE
                  </div>
                  <div style="color: #155724; font-weight: bold;">${entreesStr || '-'}</div>
                </div>
                <div style="flex: 1; background: #f8d7da; border-radius: 8px; padding: 8px; text-align: center;">
                  <div style="color: #721c24; font-weight: bold; font-size: 12px; margin-bottom: 4px;">
                    <i class="fas fa-sign-out-alt me-1"></i> SORTIE
                  </div>
                  <div style="color: #721c24; font-weight: bold;">${sortiesStr || '-'}</div>
                </div>
              </div>
            </div>
          `;
        });
        if (container) container.innerHTML = html;
      })
      .catch(function() {
        var el = document.getElementById('todayList');
        if (el) el.innerHTML = '<div class="text-center text-muted p-3">Erreur de chargement</div>';
      });
      } catch(e) { console.log('loadTodayList error:', e); }
    }

    function loadEmployeesStatus() {
      try {
      var container = document.getElementById('employeesList');
      if (!container) return;
      
      fetch('/api/employees-status')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!container) return;
        if (data.length === 0) {
          container.innerHTML = '<div class="text-center text-muted p-3">Aucun employé</div>';
          return;
        }
        
        let html = '';
        data.forEach(function(emp) {
          const status = emp.status || 'absent';
          let bgColor, borderColor, icon, textColor, statusText;
          
          if (status === 'present') {
            bgColor = '#d4edda';
            borderColor = '#28a745';
            icon = 'fa-check-circle';
            textColor = '#155724';
            statusText = 'Présent';
          } else if (status === 'sortie') {
            bgColor = '#fff3cd';
            borderColor = '#ffc107';
            icon = 'fa-sign-out-alt';
            textColor = '#856404';
            statusText = 'Sortie';
          } else {
            bgColor = '#f8d7da';
            borderColor = '#dc3545';
            icon = 'fa-times-circle';
            textColor = '#721c24';
            statusText = 'Absent';
          }
          
          html += `
            <div class="emp-item" style="display: flex; align-items: center; padding: 12px 15px; border-bottom: 1px solid #f0f0f0;">
              <div style="width: 30px; height: 30px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-right: 12px; background: ${bgColor}; border: 2px solid ${borderColor};">
                <i class="fas ${icon}" style="color: ${textColor};"></i>
              </div>
              <div class="emp-info" style="flex: 1;">
                <div style="font-weight: bold; color: #333;">${emp.prenom} ${emp.nom}</div>
                <div style="font-size: 12px; color: #666;">${emp.poste || ''}</div>
              </div>
              <div style="font-weight: bold; color: ${textColor};">
                ${statusText}
              </div>
            </div>
          `;
        });
        if (container) container.innerHTML = html;
      })
      .catch(function() {
        var el = document.getElementById('employeesList');
        if (el) el.innerHTML = '<div class="text-center text-muted p-3">Erreur de chargement</div>';
      });
      } catch(e) { console.log('loadEmployeesStatus error:', e); }
    }

    // Initialize scanner only if secure context
    function updateDateTime() {
      const now = new Date();
      const timeEl = document.getElementById('currentTime');
      const dateEl = document.getElementById('currentDate');
      
      const timeStr = now.toLocaleTimeString('fr-FR', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
      const dateStr = now.toLocaleDateString('fr-FR', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' });
      
      if (timeEl) timeEl.textContent = timeStr;
      if (dateEl) dateEl.textContent = dateStr.charAt(0).toUpperCase() + dateStr.slice(1);
    }
    
    updateDateTime();
    setInterval(updateDateTime, 1000);
    
    let refreshInterval = null;
    let scannerInitialized = false;
    
    // Initialize scanner only when user clicks the button
    function initScanner() {
      var readerEl = document.getElementById('reader');
      if (!readerEl) return;
      if (scannerInitialized && html5QrcodeScanner) {
        // Scanner already initialized, just restart if not running
        if (!html5QrcodeScanner.isScanning) {
          html5QrcodeScanner.resume();
        }
        return;
      }
      scannerInitialized = true;
      
      // Ensure reader has proper size
      readerEl.style.width = '100%';
      // Responsive height based on screen size
      var isMobile = window.innerWidth < 576;
      var isTablet = window.innerWidth >= 576 && window.innerWidth < 992;
      readerEl.style.minHeight = isMobile ? '280px' : (isTablet ? '400px' : '520px');
      
      try {
        // Responsive scan box size
        var w = readerEl.clientWidth || (isMobile ? 320 : 600);
        var box = isMobile ? Math.floor(w * 0.7) : Math.floor(Math.min(420, Math.max(220, w * 0.55)));
        var qrbox = { width: box, height: box };

        html5QrcodeScanner = new Html5QrcodeScanner(
          "reader",
          { fps: 10, qrbox: qrbox },
          false
        );
        html5QrcodeScanner.render(onScanSuccess, onScanFailure);
        console.log('Camera initialized');
      } catch (e) {
        console.log('Camera init error:', e);
        scannerInitialized = false; // Allow retry on failure
        readerEl.innerHTML = '<div class="alert alert-danger">Erreur caméra: ' + e.message + '</div>';
      }
    }
    
    function openCameraScanner() {
      initScanner();
    }
    
    window.onload = function() {
      console.log('Page loaded, protocol:', window.location.protocol, 'hostname:', window.location.hostname);
      
      // Load initial data
      loadTodayList();
      loadEmployeesStatus();
      
      // Don't auto-initialize scanner - wait for user click
      // Scanner will init when user clicks "Ouvrir la caméra" button
      
      // Auto-refresh every 10 seconds (only if not on scanner tab)
      refreshInterval = setInterval(function() {
        try {
          var activeTab = document.querySelector('.tab-pane.active');
          if (activeTab && (activeTab.id === 'historique-pane' || activeTab.id === 'employes-pane')) {
            loadTodayList();
            loadEmployeesStatus();
          }
        } catch(e) { console.log('Refresh error:', e); }
      }, 10000);
    };
    
    // Cleanup on page unload
    window.onunload = function() {
      if (refreshInterval) clearInterval(refreshInterval);
    };

    function showCameraError() {
      const reader = document.getElementById('reader');
      if (reader) {
        reader.innerHTML = `
          <div class="alert alert-warning text-center">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Camera non disponible</strong><br>
            <small>Cliquez sur "Ouvrir la caméra" pour activer le scanner.</small>
          </div>
        `;
      }
    }

    // Toast notification styles
    var style = document.createElement('style');
    style.textContent = `
      .toast-notification {
        position: fixed;
        top: 20px;
        right: 20px;
        padding: 16px 24px;
        border-radius: 10px;
        color: #fff;
        font-weight: 600;
        font-size: 1rem;
        z-index: 10000;
        opacity: 0;
        transform: translateX(100%);
        transition: all 0.3s ease;
        box-shadow: 0 4px 20px rgba(0,0,0,0.4);
      }
      .toast-notification.show {
        opacity: 1;
        transform: translateX(0);
      }
      .toast-entrer { background: #2ecc71; }
      .toast-sortie { background: #f39c12; color: #000; }
    `;
    document.head.appendChild(style);

    function showNotification(message, type) {
      var notif = document.createElement('div');
      notif.className = 'toast-notification toast-' + type;
      notif.innerHTML = message;
      document.body.appendChild(notif);
      setTimeout(function() { notif.classList.add('show'); }, 10);
      setTimeout(function() {
        notif.classList.remove('show');
        setTimeout(function() { notif.remove(); }, 300);
      }, 4000);
    }

    var evtSource = new EventSource('/api/notifications/scan');
    evtSource.onmessage = function(e) {
      try {
        var data = JSON.parse(e.data);
        var message = data.type === 'entrer' 
          ? 'Arrivée de ' + data.employe.prenom + ' ' + data.employe.nom
          : 'Sortie de ' + data.employe.prenom + ' ' + data.employe.nom;
        showNotification(message, data.type);
      } catch(err) {}
    };
    evtSource.onerror = function() {
      setTimeout(function() { evtSource = new EventSource('/api/notifications/scan'); }, 5000);
    };
  </script>
</body>
</html>
