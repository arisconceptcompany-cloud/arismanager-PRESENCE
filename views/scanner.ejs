<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Scanner présence - PresenceAris</title>
  <link rel="icon" type="image/png" href="/logo.png">
  <link rel="stylesheet" href="/css/style.css">
  <script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>
</head>
<body>
  <%- include('partials/header') %>
  <main class="main-content">
    <div class="page-scanner">
      <h1>Scanner badge</h1>
      <p class="lead">Présentez le QR code du badge devant la caméra pour enregistrer une <strong>entrée</strong> ou <strong>sortie</strong>.</p>
      <div class="scanner-container">
        <div id="reader" class="qr-reader"></div>
        <div id="scan-result" class="scan-result hidden">
          <div class="result-employee-info"></div>
          <button type="button" id="scan-again" class="btn btn-primary">Scanner à nouveau</button>
        </div>
      </div>
      <p class="scanner-hint">Autorisez l'accès à la caméra si demandé.</p>
    </div>
  </main>
  <%- include('partials/footer') %>
  <script src="/js/scanner.js"></script>
</body>
</html>
