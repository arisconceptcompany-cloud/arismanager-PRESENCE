<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ARIS - Pointage</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <style>
    body {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .login-card {
      background: white;
      border-radius: 20px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.3);
      padding: 40px;
      max-width: 400px;
      width: 100%;
    }
    .logo {
      text-align: center;
      margin-bottom: 30px;
    }
    .logo img {
      width: 80px;
      height: 80px;
      border-radius: 50%;
    }
    .logo h2 {
      color: #1e3c72;
      margin-top: 15px;
      font-weight: bold;
    }
    .form-control {
      border-radius: 10px;
      padding: 12px 15px;
      border: 2px solid #e0e0e0;
    }
    .form-control:focus {
      border-color: #2a5298;
      box-shadow: none;
    }
    .btn-primary {
      background: linear-gradient(135deg, #1e3c72 0%, #2a5298 100%);
      border: none;
      border-radius: 10px;
      padding: 12px;
      font-weight: bold;
    }
    .btn-primary:hover {
      background: linear-gradient(135deg, #2a5298 0%, #1e3c72 100%);
    }
    .error {
      background: #fee;
      color: #c00;
      padding: 12px;
      border-radius: 10px;
      margin-bottom: 20px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="login-card">
    <div class="logo">
      <i class="fas fa-qrcode" style="font-size: 60px; color: #1e3c72;"></i>
      <h2>ARIS Presence</h2>
      <p class="text-muted">Scan de badge</p>
    </div>
    
    <% if (error) { %>
      <div class="error"><%= error %></div>
    <% } %>
    
    <form method="POST" action="/employe-login">
      <div class="mb-3">
        <label class="form-label">Code badge / ID</label>
        <input type="text" name="code" class="form-control" placeholder="Entrez votre code" required autofocus>
      </div>
      <button type="submit" class="btn btn-primary w-100">
        <i class="fas fa-sign-in-alt me-2"></i> Se connecter
      </button>
    </form>
    
    <div class="text-center mt-3">
      <a href="/login" class="text-muted text-decoration-none">
        <i class="fas fa-user-shield me-1"></i> Espace Admin
      </a>
    </div>
  </div>
</body>
</html>
